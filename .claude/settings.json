{
  "env": {
    "CLAUDE_CODE_ENABLE_TELEMETRY": "1",
    "CLAUDE_CODE_ENHANCED_TELEMETRY_BETA": "1",
    "OTEL_TRACES_EXPORTER": "otlp",
    "OTEL_METRICS_EXPORTER": "otlp",
    "OTEL_LOGS_EXPORTER": "otlp",
    "OTEL_EXPORTER_OTLP_PROTOCOL": "grpc",
    "OTEL_EXPORTER_OTLP_ENDPOINT": "https://api.honeycomb.io",
    "OTEL_EXPORTER_OTLP_HEADERS": "x-honeycomb-team=YOUR_API_KEYß",
    "OTEL_SERVICE_NAME": "claude-code",

    "OTEL_LOG_USER_PROMPTS": "0",
    "OTEL_LOG_TOOL_DETAILS": "0",
    "OTEL_LOG_TOOL_CONTENT": "0"
  },

  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/hook_session_start.py",
            "timeout": 10
          }
        ]
      }
    ],

    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/hook_session_end.py",
            "timeout": 10
          }
        ]
      }
    ],

    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/hook_user_prompt_submit.py",
            "timeout": 10
          }
        ]
      }
    ],

    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/hook_pre_tool_use.py",
            "timeout": 10
          }
        ]
      }
    ],

    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/hook_post_tool_use.py",
            "timeout": 10
          }
        ]
      }
    ],

    "PostToolUseFailure": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/hook_post_tool_use_failure.py",
            "timeout": 10
          }
        ]
      }
    ],

    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/hook_stop.py",
            "timeout": 10
          }
        ]
      }
    ],

    "StopFailure": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/hook_stop_failure.py",
            "timeout": 10
          }
        ]
      }
    ],

    "SubagentStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/hook_subagent_start.py",
            "timeout": 10
          }
        ]
      }
    ],

    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/hook_subagent_stop.py",
            "timeout": 10
          }
        ]
      }
    ],

    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/hook_pre_compact.py",
            "timeout": 10
          }
        ]
      }
    ],

    "PostCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/hook_post_compact.py",
            "timeout": 10
          }
        ]
      }
    ],

    "PermissionRequest": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/hook_permission_request.py",
            "timeout": 10
          }
        ]
      }
    ],

    "PermissionDenied": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/hook_permission_denied.py",
            "timeout": 10
          }
        ]
      }
    ],

    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/hook_notification.py",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
